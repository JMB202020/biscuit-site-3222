            <label class="block text-sm font-700 text-[var(--color-ink)] mb-1">Your Name</label>
            <input type="text" name="name" required class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-[var(--color-ink)] bg-white focus:outline-none focus:border-[var(--color-brand-accent)]" />
          </div>
          <div>
            <label class="block text-sm font-700 text-[var(--color-ink)] mb-1">Email Address</label>
            <input type="email" name="email" required class="w-full border border-[var(--color-border)] rounded-lg px-4 py-2.5 text-[var(--color-ink)] bg-white focus:outline-none focus:border-[var(--color-brand-accent)]" />
          </div>
          <div>
            <label class="block text-sm font-700 text-[var(--color-ink)] mb-1">Phone Number</label>
